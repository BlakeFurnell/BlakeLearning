    "plt.grid(True, alpha=0.3)\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(recalls, precisions, color='darkorange', linewidth=2)\n",
    "plt.scatter(recalls[best_thresh_idx], precisions[best_thresh_idx], \n",
